FROM `da-2025-481513.pbi.orders_data` o
JOIN `da-2025-481513.pbi.product_data` p ON o.ProdNumber = p.ProdNumber
JOIN `da-2025-481513.pbi.productCategory_data` pc ON p.Category = pc.CategoryID
